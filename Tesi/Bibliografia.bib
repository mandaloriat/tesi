@incollection{AMS_hypre,
	title = {Scaling {Hypre}’s {Multigrid} {Solvers} to 100,000 {Cores}},
	copyright = {©2012 Springer-Verlag London Limited},
	abstract = {The hypre software library (http://​www.​llnl.​gov/​CASC/​hypre/​) is a collection of high performance preconditioners and solvers for large sparse linear systems of equations on massively parallel machines. This paper investigates the scaling properties of several of the popular multigrid solvers and system building interfaces in hypre on two modern parallel platforms. We present scaling results on over 100,000 cores and even solve a problem with over a trillion unknowns.},
	language = {en},
	booktitle = {High-{Performance} {Scientific} {Computing}},
	publisher = {Springer London},
	author = {Baker, Allison H. and Falgout, Robert D. and Kolev, Tzanio V. and Yang, Ulrike Meier},
